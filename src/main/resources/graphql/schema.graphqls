type Mutation {
  createPlayer(playerInput: PlayerInput!): Players!
}

type Query {
  allPlayers: [Players]
  getPlayers(playerId: ID!): Players
}

enum team {
  CSK
  MI
  RCB
  KKR
}

type Players {
  id: ID
  name: String
  team: team
  age: Int
  address: String
  height: Float
  email: String
}

input PlayerInput {
  name: String
  team: team
  age: Int
  address: String
  height: Float
  email: String
}